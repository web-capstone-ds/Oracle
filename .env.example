# ─────────────────────────────────────────────────
# DS Oracle 판정 엔진 서버 환경변수 (예시)
# ─────────────────────────────────────────────────

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=ds_oracle_001
MQTT_USERNAME=oracle_server
MQTT_PASSWORD=oracle_secret
MQTT_KEEPALIVE_SEC=60
MQTT_SESSION_EXPIRY_SEC=3600

# Oracle DB (Rule DB + 판정 이력)
ORACLE_DB_HOST=localhost
ORACLE_DB_PORT=5434
ORACLE_DB_NAME=oracle
ORACLE_DB_USER=oracle
ORACLE_DB_PASSWORD=oracle_secret
ORACLE_DB_POOL_MIN=1
ORACLE_DB_POOL_MAX=5

# Historian DB (TSDB 읽기 전용)
HISTORIAN_DB_HOST=localhost
HISTORIAN_DB_PORT=5433
HISTORIAN_DB_NAME=ds_historian
HISTORIAN_DB_USER=oracle_reader
HISTORIAN_DB_PASSWORD=reader_secret
HISTORIAN_DB_POOL_MIN=1
HISTORIAN_DB_POOL_MAX=5

# Rule Cache
RULE_CACHE_TTL_SEC=300

# Graceful Shutdown
SHUTDOWN_TIMEOUT_SEC=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
